            738,
            1000,
            823
          ],
          "block_id": 2,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "State, county and local health agencies ",
          "block_bbox": [
            42,
            991,
            1532,
            1070
          ],
          "block_id": 3,
          "block_order": 4
        },
        {
          "block_label": "text",
          "block_content": "State, county and local welfare agencies ",
