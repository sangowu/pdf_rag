        },
        {
          "block_label": "text",
          "block_content": "Peter: Hi,Amy! What's the weather like in Shanghai today?",
          "block_bbox": [
            196,
            1285,
            1360,
            1327
          ],
          "block_id": 12,
          "block_order": 10
        },
        {
          "block_label": "text",
          "block_content": "Amy: Hello,Peter! It's sunny and warm here. I'm going to the zoo this afternoon.",
          "block_bbox": [
            195,
            1367,
            1797,
            1411
          ],
          "block_id": 13,
          "block_order": 11
        },
        {
          "block_label": "text",
          "block_content": "Peter: That's cool!",
          "block_bbox": [
            192,
            1448,
            561,
            1486
          ],
          "block_id": 14,
          "block_order": 12
        },
        {
          "block_label": "text",
          "block_content": "Amy: Peter,how is the weather in Beijing now?",
          "block_bbox": [
            188,
            1534,
            1092,
            1576
          ],
          "block_id": 15,
          "block_order": 13
        },
        {
          "block_label": "text",
          "block_content": "Peter: It's cloudy. It's going to rain. So I can't fly a kite in the park.",
          "block_bbox": [
            183,
            1616,
            1548,
            1663
          ],
          "block_id": 16,
          "block_order": 14
        },
        {
          "block_label": "text",
          "block_content": "Amy: Oh,I see.",
          "block_bbox": [
            182,
            1699,
            487,
            1739
          ],
          "block_id": 17,
          "block_order": 15
        },
        {
          "block_label": "text",
          "block_content": "Peter: Do you know the weather in Guangzhou?",
          "block_bbox": [
            176,
            1783,
            1095,
            1830
          ],
          "block_id": 18,
          "block_order": 16
        },
        {
          "block_label": "text",
          "block_content": "Amy:It's very hot there. The children there usually go swimming in the sea.It's going to rain this afternoon.\n",
          "block_bbox": [
            174,
            1870,
            1883,
            1993
          ],
          "block_id": 19,
          "block_order": 17
        },
        {
          "block_label": "text",
          "block_content": "Peter: Oh,I like swimming too. But I can't swim now. It's a little cold.",
          "block_bbox": [
            165,
            2037,
            1547,
            2082
          ],
          "block_id": 20,
          "block_order": 18
        },
        {
          "block_label": "text",
          "block_content": "()1.It's fine in Shanghai.",
          "block_bbox": [
            160,
            2119,
            768,
            2167
          ],
          "block_id": 21,
          "block_order": 19
        },
        {
          "block_label": "text",
          "block_content": "()2.Peter is in Guangzhou.",
          "block_bbox": [
            158,
            2204,
            782,
            2254
          ],
          "block_id": 22,
          "block_order": 20
        },
        {
          "block_label": "text",
          "block_content": "()3.It's cloudy in Beijing.",
          "block_bbox": [
            154,
            2288,
            774,
            2345
          ],
          "block_id": 23,
          "block_order": 21
        },
        {
          "block_label": "text",
          "block_content": "()4.It's cool in Guangzhou.",
          "block_bbox": [
            150,
            2373,
            797,
            2429
          ],
          "block_id": 24,
          "block_order": 22
        },
        {
          "block_label": "text",
          "block_content": "C )5.Amy is going to swim.微信公众号",
