          "block_order": 1
        },
        {
          "block_label": "text",
          "block_content": "Anticipation—A WebApp should be designed so that it anticipates the use's next move.\n",
          "block_bbox": [
            113,
            504,
            2770,
            668
          ],
          "block_id": 1,
          "block_order": 2
        },
        {
          "block_label": "text",
          "block_content": "Communication—The interface should communicate the status of any activity initiated by the user \n",
          "block_bbox": [
            100,
            707,
            2797,
            880
          ],
          "block_id": 2,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "Consistency—The use of navigation controls, menus, icons, and aesthetics (e.g., color, shape, layout)\n",
          "block_bbox": [
            95,
            918,
            2616,
            1093
          ],
          "block_id": 3,
          "block_order": 4
        },
        {
          "block_label": "text",
          "block_content": "Controlled autonomy—The interface should facilitate user movement throughout the WebApp, but it should do so in a manner that enforces navigation conventions that have been established for the application.",
          "block_bbox": [
            91,
            1129,
            2810,
            1394
          ],
          "block_id": 4,
          "block_order": 5
        },
        {
          "block_label": "text",
          "block_content": "Efficiency—The design of the WebApp and its interface should optimize the user's work efficiency, not the efficiency of the Web engineer who designs and builds it or the client-server environment that executes it.\n",
          "block_bbox": [
            88,
            1434,
            2758,
            1800
          ],
          "block_id": 5,
          "block_order": 6
        }
      ],
