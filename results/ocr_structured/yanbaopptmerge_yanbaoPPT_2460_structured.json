        {
          "block_label": "formula",
          "block_content": "\\begin{aligned}\\mathbf{P}& 第 \\left(\\lambda_{1}\\quad\\lambda_{2}\\right)\\quad\\mathbf{P}^{-1}\\mathbf{A}\\mathbf{P}=\\left(\\lambda_{1}\\quad\\lambda\\right)\\\\\\left\\{\\begin{aligned}\\frac{d u}{d t}=\\lambda u\\\\ \\frac{d v}{d t}=\\lambda v\\end{aligned}\\right.&\\left\\{\\begin{aligned}u=u_{0}e^{\\lambda t}\\\\ v=v_{0}e^{\\lambda t}\\end{aligned}\\right.\\quad\\frac{u}{v}=\\frac{u_{0}}{v_{0}}\\\\\\bullet\\quad&\\alpha<0,\\lambda<0\\\\\\bullet\\quad&\\alpha>0,\\lambda>0\\end{aligned}",
          "block_bbox": [
            180,
            745,
            1791,
            1770
          ],
          "block_id": 3,
          "block_order": 4
        },
        {
          "block_label": "formula",
          "block_content": "\\begin{aligned}\\frac{d\\mathbf{u}}{dt}&=\\mathbf{P}^{-1}\\mathbf{A}\\mathbf{P}\\mathbf{u}\\\\\\alpha&=tr(\\mathbf{A})=\\lambda_1+\\lambda_2\\\\\\beta&=|\\mathbf{A}|=\\lambda_1\\lambda_2\\end{aligned}",
