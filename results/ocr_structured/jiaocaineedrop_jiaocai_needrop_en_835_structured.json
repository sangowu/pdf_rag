            879,
            847
          ],
          "block_id": 7,
          "block_order": 5
        },
        {
          "block_label": "text",
          "block_content": "和家人分享\n",
          "block_bbox": [
            779,
            932,
            933,
            1092
          ],
          "block_id": 8,
          "block_order": 6
        },
        {
          "block_label": "paragraph_title",
          "block_content": "二、我会选一选",
          "block_bbox": [
            101,
            1192,
            492,
            1245
          ],
          "block_id": 9,
          "block_order": 7
        },
        {
          "block_label": "text",
          "block_content": "①想办法②美味③快乐",
          "block_bbox": [
            254,
            1310,
            886,
            1358
          ],
          "block_id": 10,
          "block_order": 8
        },
        {
          "block_label": "text",
          "block_content": "1.我把妈妈做的饼干带给同学们吃，他们觉得饼干很(）。\n",
          "block_bbox": [
            190,
            1422,
            976,
            1581
          ],
          "block_id": 11,
          "block_order": 9
        },
        {
          "block_label": "text",
          "block_content": "2.我把自己的困难讲给老师听，他会帮我( )。\n",
          "block_bbox": [
            1082,
            548,
            1861,
            694
          ],
          "block_id": 12,
          "block_order": 10
        },
        {
          "block_label": "text",
          "block_content": "3.我给小伙伴们唱了一首好听的歌，他们会感到很(）。\n",
          "block_bbox": [
            1082,
            755,
            1865,
            907
          ],
          "block_id": 13,
          "block_order": 11
        },
        {
          "block_label": "paragraph_title",
          "block_content": "三、我会写一写",
          "block_bbox": [
            1021,
            1004,
            1364,
            1052
          ],
          "block_id": 14,
          "block_order": 12
        },
        {
          "block_label": "image",
          "block_content": "分享还有\n\n什么魔力呢？\n\n",
