            611
          ],
          "block_id": 4,
          "block_order": 2
        },
        {
          "block_label": "text",
          "block_content": "读到一本好书\n妈妈买回新鲜的草莓游戏新玩法\n爸爸给我买了生日蛋糕",
          "block_bbox": [
            178,
            693,
            628,
            1075
          ],
          "block_id": 5,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "和同学",
          "block_bbox": [
            789,
            696,
            931,
            743
          ],
          "block_id": 6,
          "block_order": 4
        },
        {
          "block_label": "text",
          "block_content": "分享",
          "block_bbox": [
            787,
