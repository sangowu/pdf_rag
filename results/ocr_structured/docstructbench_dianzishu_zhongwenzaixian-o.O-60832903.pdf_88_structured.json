    "core_content": {
      "parsing_res_list": [
        {
          "block_label": "text",
          "block_content": "\"Who are you?\" said Lucie. \"Have you seen my pocket-handkins?\"",
          "block_bbox": [
            59,
            42,
            653,
            105
          ],
          "block_id": 0,
          "block_order": 1
        },
        {
          "block_label": "image",
          "block_content": "",
          "block_bbox": [
            42,
            156,
            322,
            484
          ],
          "block_id": 1,
          "block_order": null
        },
        {
          "block_label": "text",
          "block_content": "The little person made a bob-curtsey—\"Oh, yes, if you please'm; my name is Mrs.Tiggy-winkle; oh, yes if you please'm, I'm an excellent clear-starcher!\" And she took something out of a clothes-basket, and spread it on the ironing-blanket.",
          "block_bbox": [
            331,
            148,
            654,
            495
          ],
          "block_id": 2,
          "block_order": 2
        },
        {
          "block_label": "text",
          "block_content": "\"What's that thing?\" said Lucie—\"that's not my pocket-handkin?\"",
          "block_bbox": [
            58,
            536,
            656,
            604
          ],
          "block_id": 3,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "\"Oh no, if you please'm;that's a little scarlet waistcoat belonging to Cock Robin!\"",
          "block_bbox": [
            60,
            642,
            373,
            789
          ],
          "block_id": 4,
          "block_order": 4
        },
        {
          "block_label": "text",
          "block_content": "And she ironed it and folded it, and put it on one side.\n",
          "block_bbox": [
            63,
            829,
            372,
            931
          ],
          "block_id": 5,
          "block_order": 5
        },
