            1776,
            760,
            1856
          ],
          "block_id": 13,
          "block_order": null
        },
        {
          "block_label": "paragraph_title",
          "block_content": "生活大舞台",
          "block_bbox": [
            773,
            1809,
            997,
            1854
          ],
          "block_id": 14,
          "block_order": 13
        },
        {
          "block_label": "text",
          "block_content": "修一条公路，原计划40人来修，12天完成。实际修路时增加了一些人（每人每天修路的速度不变），结果比计划提前2天完成。你知道增加了多少人吗？（用比例知识解答）\n",
          "block_bbox": [
            669,
