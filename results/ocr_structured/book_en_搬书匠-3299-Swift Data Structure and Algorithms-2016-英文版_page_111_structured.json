        },
        {
          "block_label": "text",
          "block_content": "/// Initialization \n\nvar priorityQueue = PriorityQueue<String>(ascending: true)\n/// Initializing with starting values \npriorityQueue = PriorityQueue<String>(ascending:: true, startingValues:\n[\"Coldplay\", \"OneRepublic\", \"Maroon 5\", \"Imagine Dragons\", \"The Script\"])\nvar x = priorityQueue.pop()\n\n/// Coldplay \n\nx = priorityQueue.pop( )\n\n///1Imagine Dragons \n\n",
          "block_bbox": [
            302,
            1014,
            2705,
            1832
          ],
          "block_id": 4,
          "block_order": 3
        },
        {
          "block_label": "paragraph_title",
          "block_content": "Protocols ",
          "block_bbox": [
            217,
            1985,
            719,
            2068
          ],
          "block_id": 5,
          "block_order": 4
        },
        {
          "block_label": "text",
          "block_content": "The PriorityQueue conforms to sequence, collection, and IteratorProtocol, so you can treat it like any other Swift sequence and collection:",
          "block_bbox": [
            217,
            2117,
            2808,
            2269
          ],
          "block_id": 6,
          "block_order": 5
        },
        {
          "block_label": "text",
          "block_content": "extension PriorityQueue: IteratorProtocol {\npublic typealias Element = T mutating public func next() -> Element? { return pop() }\n}\nextension PriorityQueue: Sequence {\npublic typealias Iterator = PriorityQueue public func makeIterator() -> Iterator { return self }\n",
          "block_bbox": [
            332,
            2333,
            2293,
            2929
          ],
          "block_id": 7,
          "block_order": 6
        },
        {
          "block_label": "text",
          "block_content": "This allows you to use Swifft standard library functions on a PriorityQueue and iterate through a PriorityQueue like this:",
          "block_bbox": [
            232,
            2982,
            2737,
            3147
          ],
          "block_id": 8,
          "block_order": 7
        },
        {
          "block_label": "text",
          "block_content": "for x in priorityQueue {\nprint(x)\n\n}\n\n// Coldplay \n\n",
          "block_bbox": [
            347,
            3209,
            1136,
            3540
          ],
          "block_id": 9,
          "block_order": 8
        },
        {
          "block_label": "number",
          "block_content": "[97]",
          "block_bbox": [
            1468,
            3638,
            1603,
            3698
          ],
          "block_id": 10,
          "block_order": null
        }
      ],
      "markdown": "<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_280_312_541_630.jpg\" alt=\"Image\" width=\"8%\" /></div>\n\n\nTk Sedgewick and Wayne, Fourth Edition, Section 2.4.\n\namm \n\n/// Initialization \n\nvar priorityQueue = PriorityQueue<String>(ascending: true)\n\n/// Initializing with starting values \n\npriorityQueue = PriorityQueue<String>(ascending:: true, startingValues:\n\n[\"Coldplay\", \"OneRepublic\", \"Maroon 5\", \"Imagine Dragons\", \"The Script\"])\n\nvar x = priorityQueue.pop()\n\n/// Coldplay \n\nx = priorityQueue.pop( )\n\n///1Imagine Dragons \n\n\n\n## Protocols \n\nThe PriorityQueue conforms to sequence, collection, and IteratorProtocol, so you can treat it like any other Swift sequence and collection:\n\nextension PriorityQueue: IteratorProtocol {\n\npublic typealias Element = T mutating public func next() -> Element? { return pop() }\n\n}\n\nextension PriorityQueue: Sequence {\n\npublic typealias Iterator = PriorityQueue public func makeIterator() -> Iterator { return self }\n\n\n\nThis allows you to use Swifft standard library functions on a PriorityQueue and iterate through a PriorityQueue like this:\n\nfor x in priorityQueue {\n\nprint(x)\n\n}\n\n// Coldplay \n\n",
