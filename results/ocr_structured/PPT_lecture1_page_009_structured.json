        {
          "block_label": "formula",
          "block_content": "\\begin{array}{ccc}x_{1}&-2x_{2}&+x_{3}\\\\&x_{2}&-4x_{3}\\\\&-3x_{2}&+13x_{3}\\\\\\end{array}\\begin{array}{ccc}=0\\\\=4\\\\=-9\\\\\\end{array}\\quad\\begin{array}{ccc}\\begin{bmatrix}1&-2&1&0\\\\0&1&-4&4\\\\0&-3&13&-9\\\\\\end{bmatrix}.",
