            183,
            439,
            752,
            512
          ],
          "block_id": 2,
          "block_order": 2
        },
        {
          "block_label": "text",
          "block_content": "南极：长城站(1985).中山站(1989).昆仑站(2009)；",
          "block_bbox": [
            187,
            545,
            1460,
            616
          ],
          "block_id": 3,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "北极：黄河站(200千)",
