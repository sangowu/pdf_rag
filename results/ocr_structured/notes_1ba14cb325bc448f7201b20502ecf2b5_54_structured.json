        {
          "block_label": "text",
          "block_content": "地质、海洋、生物等学科的科学研究，提供了领域最为广阔的天然实验室。",
          "block_bbox": [
            175,
            330,
            2012,
            418
          ],
          "block_id": 1,
          "block_order": 1
        },
        {
          "block_label": "text",
          "block_content": "(2)我国的科学考察站",
