        },
        {
          "block_label": "paragraph_title",
          "block_content": "1.三角恒等变换",
          "block_bbox": [
            293,
            1942,
            737,
            1994
          ],
          "block_id": 2,
          "block_order": 2
        },
        {
          "block_label": "text",
          "block_content": "万能置换公式：$\\sin x=\\frac{2\\tan\\frac{x}{2}}{1+\\tan^{2}\\frac{x}{2}};\\quad\\cos x=\\frac{1-\\tan^{2}\\frac{x}{2}}{1+\\tan^{2}\\frac{x}{2}};\\quad\\tan x=\\frac{2\\tan\\frac{x}{2}}{1-\\tan^{2}\\frac{x}{2}};$ ",
          "block_bbox": [
            275,
            2053,
            2048,
            2306
          ],
          "block_id": 3,
          "block_order": 3
        },
        {
          "block_label": "paragraph_title",
          "block_content": "（1）积化和差公式",
          "block_bbox": [
            306,
            2336,
            737,
            2386
          ],
          "block_id": 4,
          "block_order": 4
        },
        {
          "block_label": "formula",
          "block_content": "\\begin{aligned}\\sin A\\cos B&=\\frac{1}{2}\\left[\\sin(A+B)+\\sin(A-B)\\right];\\cos A\\sin B=\\frac{1}{2}\\left[\\sin(A+B)-\\sin(A-B)\\right];\\\\\\cos A\\cos B&=\\frac{1}{2}\\left[\\cos(A+B)+\\cos(A-B)\\right];\\sin A\\sin B=\\frac{1}{2}\\left[\\cos(A-B)-\\cos(A+B)\\right];\\end{aligned}",
          "block_bbox": [
            290,
            2437,
            2251,
            2740
          ],
          "block_id": 5,
          "block_order": 5
        },
        {
          "block_label": "paragraph_title",
          "block_content": "(2）和差化积公式",
          "block_bbox": [
            315,
            2791,
            740,
            2840
          ],
          "block_id": 6,
          "block_order": 6
        },
        {
          "block_label": "formula",
          "block_content": "\\begin{aligned}&\\sin A+\\sin B=2\\sin\\frac{A+B}{2}\\cos\\frac{A-B}{2};\\quad\\sin A-\\sin B=2\\cos\\frac{A+B}{2}\\sin\\frac{A-B}{2};\\\\ &\\cos A+\\cos B=2\\cos\\frac{A+B}{2}\\cos\\frac{A-B}{2};\\quad\\cos A-\\cos B=-2\\sin\\frac{A+B}{2}\\sin\\frac{A-B}{2};\\\\ \\end{aligned}",
          "block_bbox": [
            296,
            2889,
            2115,
            3195
          ],
          "block_id": 7,
          "block_order": 7
        }
      ],
