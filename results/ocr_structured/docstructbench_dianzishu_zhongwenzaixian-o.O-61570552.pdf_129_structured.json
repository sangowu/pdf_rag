[
  {
    "filename": "docstructbench_dianzishu_zhongwenzaixian-o.O-61570552.pdf_129.pdf",
    "page_index": 129,
    "core_content": {
      "parsing_res_list": [
        {
          "block_label": "paragraph_title",
          "block_content": "七、温里药",
          "block_bbox": [
            84,
            56,
            205,
            78
          ],
          "block_id": 0,
          "block_order": 1
        },
        {
          "block_label": "paragraph_title",
          "block_content": "附子",
          "block_bbox": [
            389,
            120,
            448,
            139
          ],
          "block_id": 1,
          "block_order": 2
        },
        {
          "block_label": "text",
          "block_content": "【来源】毛茛科植物乌头的子根的加工品。",
          "block_bbox": [
            113,
            145,
            404,
            167
          ],
          "block_id": 2,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "【采收加工】夏秋季采挖，除去主根、须根及泥沙，习称“泥附子”。以不同的方法加工制成盐附子、黑顺片、白附片直接入药。\n",
          "block_bbox": [
            81,
            174,
            458,
            246
          ],
          "block_id": 3,
          "block_order": 4
        },
        {
          "block_label": "text",
          "block_content": "【质量标志】盐附子以个大、体重、色灰黄、表面起盐霜者为佳。黑顺片以片大、厚薄均匀、切面油润有光泽者为佳。白附片以片大、色白、油润、半透明者为佳。水分不得超过15%\n",
          "block_bbox": [
            81,
            256,
            456,
            355
          ],
          "block_id": 4,
          "block_order": 5
        },
        {
          "block_label": "text",
          "block_content": "【饮片特征】①盐附子：呈圆锥形，顶端凹陷，",
          "block_bbox": [
            112,
            365,
            446,
            388
          ],
          "block_id": 5,
          "block_order": 6
        },
        {
          "block_label": "image",
          "block_content": "",
          "block_bbox": [
            473,
            162,
            738,
            366
          ],
          "block_id": 6,
          "block_order": null
        },
        {
          "block_label": "figure_title",
          "block_content": "图2-168黑顺片",
          "block_bbox": [
            543,
            375,
            666,
            392
          ],
          "block_id": 7,
          "block_order": null
        },
        {
          "block_label": "text",
          "block_content": "高5～8cm。表面黑褐色，粗糙，附有盐粒结晶，可见突起的支根及支根痕，断面色略淡，有1个多角形环纹。体重，质稍坚。气微，味咸而麻舌。②黑顺片（图2-168）：为纵切片，上宽下窄，长1.7~5cm，宽0.9~3cm，厚0.2~0.5cm。外皮黑褐色，切面暗黄色，油润且具光泽，呈半透明状，并有纵向导管束。质硬而脆，断面呈角质样。气微，味淡。③白附片：无残留外皮，呈黄白色，半透明，厚约0.3cm。\n",
          "block_bbox": [
            81,
            396,
            736,
            525
          ],
          "block_id": 8,
          "block_order": 7
        },
        {
          "block_label": "text",
          "block_content": "【贮藏要求】置干燥处，防潮。",
          "block_bbox": [
            113,
            534,
            323,
            551
          ],
          "block_id": 9,
          "block_order": 8
        },
        {
          "block_label": "paragraph_title",
          "block_content": "肉桂",
          "block_bbox": [
            385,
            571,
            442,
            589
          ],
          "block_id": 10,
          "block_order": 9
        },
        {
          "block_label": "text",
          "block_content": "【来源】樟科植物肉桂的树皮。",
          "block_bbox": [
            113,
            603,
            323,
            620
          ],
          "block_id": 11,
          "block_order": 10
        },
        {
          "block_label": "text",
          "block_content": "【采收加工】一般在秋季剥取，阴干。",
          "block_bbox": [
            113,
            631,
            369,
            647
          ],
          "block_id": 12,
          "block_order": 11
        },
        {
          "block_label": "text",
          "block_content": "【质量标志】药材以皮细而坚实，肉厚而沉重，断面紫红色，油性足，香气浓，辛、甜味大，嚼之无渣者为佳。水分不得超过15%，总灰分不得超过5%",
          "block_bbox": [
            82,
            658,
            453,
            729
          ],
          "block_id": 13,
          "block_order": 12
        },
        {
          "block_label": "text",
          "block_content": "【饮片特征】呈不规则的板状或卷筒状，厚$0.2\\sim0.8cm$ 。外表面呈灰棕色，有的可见灰白色斑纹。内表面呈红棕色，较平坦，有细纵纹，划处显油痕。质硬，断面不平坦，外层呈棕色、较粗糙，内层呈红棕色，有油润感，两层间可见1条黄棕色的线纹。气香浓烈，味甜、辣。（图2-169）",
          "block_bbox": [
            83,
            740,
            454,
            895
          ],
          "block_id": 14,
          "block_order": 13
        },
        {
          "block_label": "text",
          "block_content": "【贮藏要求】置阴凉且干燥处。",
          "block_bbox": [
            116,
            908,
            324,
            927
          ],
          "block_id": 15,
          "block_order": 14
        },
        {
          "block_label": "image",
          "block_content": "",
          "block_bbox": [
            469,
            606,
            736,
            803
          ],
          "block_id": 16,
          "block_order": null
        },
        {
          "block_label": "figure_title",
          "block_content": "图2-169肉桂",
          "block_bbox": [
            550,
            816,
            656,
            831
          ],
          "block_id": 17,
          "block_order": null
        },
        {
          "block_label": "paragraph_title",
          "block_content": "干姜",
          "block_bbox": [
            385,
            935,
            442,
            953
          ],
          "block_id": 18,
          "block_order": 15
        },
        {
          "block_label": "text",
          "block_content": "【来源】姜科植物委的根空。",
          "block_bbox": [
            116,
            973,
            311,
            993
          ],
          "block_id": 19,
          "block_order": 16
        },
        {
          "block_label": "text",
          "block_content": "【采收加工】冬季采收，去掉须根和泥沙，晒干或者低温干燥。趁鲜进切晒干或低温干燥者称为“干姜片”。\n",
          "block_bbox": [
            86,
            986,
            735,
            1048
          ],
          "block_id": 20,
          "block_order": 17
        },
        {
          "block_label": "footer",
          "block_content": "连销药店店员中药基础训练手册",
          "block_bbox": [
            286,
            1158,
            501,
            1174
          ],
          "block_id": 21,
          "block_order": null
        }
      ],
