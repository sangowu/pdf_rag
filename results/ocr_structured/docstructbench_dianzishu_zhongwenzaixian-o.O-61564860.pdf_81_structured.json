      "parsing_res_list": [
        {
          "block_label": "image",
          "block_content": "围棋定式解密",
          "block_bbox": [
            53,
            50,
            216,
            91
          ],
          "block_id": 0,
          "block_order": null
        },
        {
          "block_label": "paragraph_title",
          "block_content": "32飞",
          "block_bbox": [
            87,
            156,
            199,
            220
          ],
          "block_id": 1,
          "block_order": 1
        },
        {
          "block_label": "text",
          "block_content": "从原有棋子出发，向“日”字形的对角线交点处下一子叫“飞”，也叫“小飞”。\n",
          "block_bbox": [
            99,
            268,
            772,
            338
          ],
          "block_id": 2,
          "block_order": 2
        },
        {
          "block_label": "image",
          "block_content": "B \nC \n:①\n\n中\n\n",
          "block_bbox": [
            448,
            318,
            768,
            528
          ],
          "block_id": 3,
          "block_order": null
        },
        {
          "block_label": "figure_title",
          "block_content": "图2-116",
          "block_bbox": [
            556,
            550,
            642,
            569
          ],
          "block_id": 4,
          "block_order": null
        },
        {
          "block_label": "text",
          "block_content": "图2-116相对于图中原有的白棋一子来说，无论白方在A、B、C、D、E、F、G、H这些字母代表的位置上任意一处行棋，都可以称其为飞。",
          "block_bbox": [
            85,
            361,
            422,
            565
          ],
          "block_id": 5,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "图2-117相对于白方原有的一子来说，白△是飞。反过来，相对于白方△一子，白原有的一子也叫作飞。",
          "block_bbox": [
            83,
            588,
            763,
            657
          ],
          "block_id": 6,
          "block_order": 4
        },
        {
          "block_label": "text",
          "block_content": "飞的形式里还有“大飞”。它是指在原有棋子呈“目”字形的对角线交点处行棋。\n",
          "block_bbox": [
            81,
            676,
            762,
            744
          ],
          "block_id": 7,
          "block_order": 5
        },
        {
          "block_label": "text",
          "block_content": "图2-118白△就叫白棋原有一子的大飞。同样，假若白方今后在A、B、C、D、E、F、G任何一处行棋，都叫大飞。",
          "block_bbox": [
            80,
            767,
            759,
            837
          ],
          "block_id": 8,
          "block_order": 6
        },
        {
          "block_label": "image",
          "block_content": "",
          "block_bbox": [
            81,
            855,
            408,
            1109
          ],
          "block_id": 9,
