        },
        {
          "block_label": "formula",
          "block_content": "\\begin{array}{c}{\\displaystyle\\Delta\\Bigg(\\frac{u}{v}\\Bigg)=\\frac{u+\\Delta u}{v+\\Delta v}-\\frac{u}{v}=\\frac{(u+\\Delta u)v-u(v+\\Delta v)}{v(v+\\Delta v)}}\\\\ {\\displaystyle}\\\\ {\\displaystyle=\\frac{v\\Delta u-u\\Delta v}{v(v+\\Delta v)}}\\end{array}",
