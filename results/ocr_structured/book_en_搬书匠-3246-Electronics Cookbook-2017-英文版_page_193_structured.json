    "core_content": {
      "parsing_res_list": [
        {
          "block_label": "image",
          "block_content": "+V \nR2\nW E Q2\nR1\n\n—WW Q1\nGPIO pin LOAD \nGND \n\n",
          "block_bbox": [
            225,
            78,
