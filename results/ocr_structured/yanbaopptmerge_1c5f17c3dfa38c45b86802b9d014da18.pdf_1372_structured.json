        {
          "block_label": "figure_title",
          "block_content": "Figure30.45Atransmissionhologramisonethatproducesreal andvirtualimages whena laserofthesametypeasthatwhichexposedthehologram is passedthroughit.Difractionfromvariouspartsofthefilmproducesthesameinterferencepatternastheobjectthatwasusedtoexposeit.",
          "block_bbox": [
