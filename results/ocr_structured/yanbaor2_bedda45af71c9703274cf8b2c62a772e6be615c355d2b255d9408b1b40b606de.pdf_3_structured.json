    "core_content": {
      "parsing_res_list": [
        {
          "block_label": "doc_title",
          "block_content": "新经济及数字化 时代，消费市场 行业的挑战，给予 企业的机遇\n",
          "block_bbox": [
            134,
            156,
            1415,
            902
          ],
          "block_id": 0,
          "block_order": 1
        },
        {
          "block_label": "text",
          "block_content": "疫情不仅加速了消费者体验的数字化进程，同时推动了零售和消费品企业重塑其商业模式、加快数字化转型，更重要的是采用不同的战略思维模式：",
          "block_bbox": [
            112,
            1122,
            908,
            1424
          ],
          "block_id": 1,
          "block_order": 2
        },
        {
          "block_label": "text",
          "block_content": "公",
          "block_bbox": [
            1490,
            761,
            1659,
            1044
          ],
          "block_id": 2,
          "block_order": 3
        },
        {
          "block_label": "text",
          "block_content": "如何吸引并打动数字化潮流下的新生代消费者是企业的关键课题\n",
          "block_bbox": [
            1133,
            1394,
            2000,
            1520
          ],
          "block_id": 3,
          "block_order": 4
        },
        {
          "block_label": "paragraph_title",
          "block_content": "5",
          "block_bbox": [
            571,
            1752,
            647,
            1855
          ],
          "block_id": 4,
          "block_order": 5
        },
        {
          "block_label": "text",
          "block_content": "如何通过并购重组，组织变革以及税务战略等为企业带来更大的发展及业务增长",
          "block_bbox": [
            52,
            1887,
            617,
            2076
          ],
          "block_id": 5,
          "block_order": 6
        },
        {
          "block_label": "text",
          "block_content": "在数字化进程中，企业如何构建全面风险管理体系，提升企业领导力和竞争力\n",
          "block_bbox": [
            58,
            2436,
            741,
            2616
          ],
          "block_id": 6,
          "block_order": 7
        },
        {
          "block_label": "paragraph_title",
          "block_content": "2",
          "block_bbox": [
            1442,
            1779,
            1517,
            1883
          ],
          "block_id": 7,
          "block_order": 8
        },
        {
          "block_label": "text",
          "block_content": "伴随着新媒体兴起，如何挖掘线上线下协同价值成为企业的下一个增长引擎",
          "block_bbox": [
            1448,
            1921,
            2019,
            2125
          ],
          "block_id": 8,
          "block_order": 9
        },
        {
          "block_label": "paragraph_title",
          "block_content": "3",
          "block_bbox": [
            1286,
            2333,
            1367,
            2446
          ],
          "block_id": 9,
          "block_order": 10
        },
        {
          "block_label": "text",
          "block_content": "如何打通生态链，提高全渠道供应链运营效率，降低现金流等不同的经营风险也是企业的关注重点",
          "block_bbox": [
            1293,
            2510,
            2012,
            2754
          ],
          "block_id": 10,
          "block_order": 11
        },
        {
          "block_label": "number",
