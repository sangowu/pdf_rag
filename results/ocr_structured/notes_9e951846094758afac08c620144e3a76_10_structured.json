          "block_order": null
        },
        {
          "block_label": "formula",
          "block_content": "LLi \\frac{A D}{A N}=\\frac{A N}{A E};B.\\frac{B D}{M N}=\\frac{M N}{C E};C.\\frac{D N}{B M}=\\frac{N E}{M E};D.\\frac{D N-N E}{M C-B N}",
          "block_bbox": [
